# ─── WhatsApp Business Cloud API ────────────────────────────────────────────
# Получить на: https://developers.facebook.com/apps → WhatsApp → API Setup

# Постоянный токен системного пользователя (не временный токен страницы)
WA_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxx

# ID номера телефона отправителя (Phone Number ID, не сам номер)
WA_PHONE_NUMBER_ID=1234567890123456

# Версия API (оставьте как есть)
WA_API_VERSION=v19.0

# ─── Anthropic Claude API ─────────────────────────────────────────────────────
# Получить на: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Сообщение ────────────────────────────────────────────────────────────────
BASE_MESSAGE=Привет! Приглашаем тебя на наше мероприятие. Будет интересно — не пропусти!
EVENT_URL=https://example.com/event
BUTTON_TEXT=Присоединиться
EVENT_CONTEXT=Деловая конференция по технологиям в Дубае, апрель 2025 года.

# ─── Файлы ────────────────────────────────────────────────────────────────────
CONTACTS_FILE=contacts.csv
RESULTS_DIR=results
